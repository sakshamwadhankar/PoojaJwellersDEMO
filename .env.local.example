# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Analytics 4
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Business Information
VITE_BUSINESS_NAME=Your Business Name
VITE_BUSINESS_PHONE=+91-XXXXXXXXXX
VITE_BUSINESS_EMAIL=your-email@example.com
VITE_BUSINESS_ADDRESS=Your Address, City, State, PIN, Country

# Location Coordinates
VITE_BUSINESS_LATITUDE=0.0000
VITE_BUSINESS_LONGITUDE=0.0000

# Social Media
VITE_INSTAGRAM_HANDLE=your_instagram_handle
VITE_INSTAGRAM_URL=https://www.instagram.com/your_instagram_handle
VITE_FACEBOOK_URL=https://www.facebook.com/your-facebook-page

# Website URLs
VITE_WEBSITE_URL=https://your-website.vercel.app
VITE_SITEMAP_URL=https://your-website.vercel.app/sitemap.xml

# SEO Settings
VITE_SEO_ENABLED=true
VITE_ANALYTICS_ENABLED=true
VITE_PERFORMANCE_MONITORING_ENABLED=true

# Image Optimization
VITE_IMAGE_OPTIMIZATION_ENABLED=true
VITE_LAZY_LOADING_ENABLED=true
VITE_WEBP_SUPPORT=true

# Performance Targets
VITE_LCP_TARGET=2500
VITE_FID_TARGET=100
VITE_CLS_TARGET=0.1
VITE_TTFB_TARGET=600

# Content Strategy
VITE_PRIMARY_KEYWORD=Your Primary Keyword
VITE_LOCATION_KEYWORD=Your Location
VITE_CONTENT_UPDATE_FREQUENCY=monthly

# Search Console
VITE_GOOGLE_SEARCH_CONSOLE_PROPERTY=https://your-website.vercel.app

# Structured Data
VITE_ORGANIZATION_SCHEMA_ENABLED=true
VITE_LOCAL_BUSINESS_SCHEMA_ENABLED=true
VITE_PRODUCT_SCHEMA_ENABLED=true
VITE_REVIEW_SCHEMA_ENABLED=true
VITE_BREADCRUMB_SCHEMA_ENABLED=true
