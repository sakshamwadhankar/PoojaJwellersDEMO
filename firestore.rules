rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Replace YOUR_ADMIN_UID_HERE with your actual Firebase Auth UID before deploying.
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'Ke4wsFZkboOLInp9oS9KMj2QGqg1';
    }

    // Public can read, only Admin can write
    match /collections/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /reviews/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /reels/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /subcategories/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
