# SEO Configuration - Copy to .env.local and update with actual values

# Google Analytics 4
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Business Information
VITE_BUSINESS_NAME=Pooja Jewellers
VITE_BUSINESS_PHONE=+91-XXXXXXXXXX
VITE_BUSINESS_EMAIL=contact@pooja-jewellers.com
VITE_BUSINESS_ADDRESS=Gittikhadan, Nagpur, Maharashtra 440001, India

# Location Coordinates
VITE_BUSINESS_LATITUDE=21.1458
VITE_BUSINESS_LONGITUDE=79.0882

# Social Media
VITE_INSTAGRAM_HANDLE=pooja_jewellers_nagpur
VITE_INSTAGRAM_URL=https://www.instagram.com/pooja_jewellers_nagpur
VITE_FACEBOOK_URL=https://www.facebook.com/pooja-jewellers-nagpur

# Website URLs
VITE_WEBSITE_URL=https://poojajewellers.vercel.app
VITE_SITEMAP_URL=https://poojajewellers.vercel.app/sitemap.xml

# SEO Settings
VITE_SEO_ENABLED=true
VITE_ANALYTICS_ENABLED=true
VITE_PERFORMANCE_MONITORING_ENABLED=true

# Image Optimization
VITE_IMAGE_OPTIMIZATION_ENABLED=true
VITE_LAZY_LOADING_ENABLED=true
VITE_WEBP_SUPPORT=true

# Performance Targets
VITE_LCP_TARGET=2500
VITE_FID_TARGET=100
VITE_CLS_TARGET=0.1
VITE_TTFB_TARGET=600

# Content Strategy
VITE_PRIMARY_KEYWORD=Pooja Jewellers
VITE_LOCATION_KEYWORD=Gittikhadan, Nagpur
VITE_CONTENT_UPDATE_FREQUENCY=monthly

# Search Console
VITE_GOOGLE_SEARCH_CONSOLE_PROPERTY=https://poojajewellers.vercel.app

# Structured Data
VITE_ORGANIZATION_SCHEMA_ENABLED=true
VITE_LOCAL_BUSINESS_SCHEMA_ENABLED=true
VITE_PRODUCT_SCHEMA_ENABLED=true
VITE_REVIEW_SCHEMA_ENABLED=true
VITE_BREADCRUMB_SCHEMA_ENABLED=true
